# Postgres — matches docker-compose.yml defaults
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=health
POSTGRES_USER=health
POSTGRES_PASSWORD=health

# Path where Health Auto Export drops CSVs
HEALTH_EXPORT_PATH=./data/raw

# dbt — points at the directory containing profiles.yml
DBT_PROFILES_DIR=./transform

# OpenWeather One Call 3.0 — optional cross-source enrichment.
# Sign up at https://openweathermap.org/api → "One Call API 3.0" and
# generate an API key. Free tier allows 1,000 calls/day, plenty for a
# personal pipeline that fetches once per missing date. If unset, the
# weather loader no-ops and raw.weather stays empty.
# OPENWEATHER_API_KEY=
# OPENWEATHER_LAT=41.8781
# OPENWEATHER_LON=-87.6298

# Google Calendar secret iCal URL — optional cross-source enrichment.
# Settings → "Settings for my calendars" → <calendar> → "Integrate
# calendar" → copy "Secret address in iCal format" (ends in basic.ics).
# WARNING: anyone with this URL can read your full calendar — never
# commit it. Unset = calendar loader no-ops.
# CALENDAR_ICS_URL=https://calendar.google.com/calendar/ical/.../basic.ics

# Anomaly → notification pipeline.
# Rules live at config/notification_rules.yaml by default. Override the
# path if you keep rules elsewhere (e.g., a sibling private repo).
# NOTIFICATION_RULES_PATH=./config/notification_rules.yaml

# Pushover (optional) — when BOTH are set, notifications also push to
# your phone. Get a free account + app at https://pushover.net (one-time
# $5 license for the mobile app). Either missing = stdout-only.
# PUSHOVER_TOKEN=
# PUSHOVER_USER=

# Test mode — when set, notifications go to stdout regardless of Pushover
# config and are logged with transport='dry_run' so a post-mortem can
# distinguish rehearsals from real fires.
# NOTIFY_DRY_RUN=true
